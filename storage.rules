rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Imagens de jogos — apenas admins fazem upload
    match /games/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
           in ['admin', 'superadmin']
        && request.resource.size < 5 * 1024 * 1024  // máx 5MB
        && request.resource.contentType.matches('image/.*');
    }

    // Avatares de usuário — só o próprio usuário
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
